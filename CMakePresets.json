{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-x64-vcpkg",
      "displayName": "Windows x64 with vcpkg",
      "description": "Configure using vcpkg toolchain and x64-windows triplet",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows/x64/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-x86-vcpkg",
      "displayName": "Windows x86 with vcpkg",
      "description": "Configure using vcpkg toolchain and x86-windows triplet",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/windows/x86/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x86-windows"
      },
      "environment": {
        "VCPKG_DEFAULT_TRIPLET": "x86-windows"
      }
    },
    {
      "name": "windows-arm64-vcpkg",
      "displayName": "Windows arm64 with vcpkg",
      "description": "Configure using vcpkg toolchain and arm64-windows triplet",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows/arm64/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-windows"
      }
    },
    {
      "name": "linux-x64-gcc",
      "displayName": "Linux x64 with GCC",
      "description": "Configure using GCC on Linux (x64)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux/x64/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-O2 -Wall",
        "CMAKE_CXX_FLAGS": "-O2 -Wall",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-x86-gcc",
      "displayName": "Linux x86 with GCC",
      "description": "Configure using GCC on Linux (x86)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux/x86/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-m32 -O2 -Wall",
        "CMAKE_CXX_FLAGS": "-m32 -O2 -Wall",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "CFLAGS": "-m32",
        "CXXFLAGS": "-m32",
        "LDFLAGS": "-m32"
      }
    },
    {
      "name": "linux-arm64-gcc",
      "displayName": "Linux arm64 with GCC",
      "description": "Configure using GCC on Linux (arm64)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux/arm64/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-O2 -Wall",
        "CMAKE_CXX_FLAGS": "-O2 -Wall",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "macos-x64-clang",
      "displayName": "macOS x64 with Clang",
      "description": "Configure using Clang on macOS (x64)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos/x64/${presetName}",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-O2 -Wall",
        "CMAKE_CXX_FLAGS": "-O2 -Wall",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "macos-arm64-clang",
      "displayName": "macOS arm64 with Clang",
      "description": "Configure using Clang on macOS (arm64)",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos/arm64/${presetName}",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_C_FLAGS": "-O2 -Wall",
        "CMAKE_CXX_FLAGS": "-O2 -Wall",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-vcpkg-Release",
      "configurePreset": "windows-x64-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-vcpkg-Debug",
      "configurePreset": "windows-x64-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-x86-vcpkg-Release",
      "configurePreset": "windows-x86-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "windows-arm64-vcpkg-Release",
      "configurePreset": "windows-arm64-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "linux-x64-gcc-Release",
      "configurePreset": "linux-x64-gcc",
      "configuration": "Release"
    },
    {
      "name": "linux-x86-gcc-Release",
      "configurePreset": "linux-x86-gcc",
      "configuration": "Release"
    },
    {
      "name": "linux-arm64-gcc-Release",
      "configurePreset": "linux-arm64-gcc",
      "configuration": "Release"
    },
    {
      "name": "macos-x64-clang-Release",
      "configurePreset": "macos-x64-clang",
      "configuration": "Release"
    },
    {
      "name": "macos-arm64-clang-Release",
      "configurePreset": "macos-arm64-clang",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-x64-gcc-Release",
      "configurePreset": "linux-x64-gcc",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
